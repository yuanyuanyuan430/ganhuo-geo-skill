{
  "repo_name": "ganhuo-geo-skill",
  "version": "0.1.0",
  "description": "面向中国内容团队的干活 GEO Skill，用于把旧文章、产品页、教程和知识库内容改造成 AI 搜索友好的内容资产。",
  "license": "MIT",
  "primary_skill": "ganhuo-geo-engineer",
  "skills": [
    {
      "name": "ganhuo-geo-engineer",
      "path": "skills/ganhuo-geo-engineer/SKILL.md",
      "description": "诊断并重构旧文章、产品页、教程和知识库内容，输出 GEO 友好正文、评分卡、改造说明、待补清单和风险提示。",
      "status": "active",
      "maturity": "production-draft",
      "primary_outputs": [
        "rewritten_content",
        "geo_scorecard",
        "change_notes",
        "supplement_backlog",
        "risk_notes"
      ]
    }
  ],
  "references": [
    "skills/ganhuo-geo-engineer/references/geo-material-notes.md",
    "skills/ganhuo-geo-engineer/references/geo-playbook.md",
    "skills/ganhuo-geo-engineer/references/geo-output-standard.md",
    "skills/ganhuo-geo-engineer/references/geo-anti-patterns.md"
  ],
  "validation": {
    "script": "scripts/validate_skill.py",
    "checks": [
      "manifest_json",
      "skill_frontmatter",
      "ganhuo_geo_prefix",
      "required_files",
      "relative_links",
      "non_empty_examples",
      "no_outputs_directory",
      "no_placeholder_text"
    ]
  },
  "examples": [
    "examples/01-real-brief.md",
    "examples/02-ideal-output.md",
    "examples/03-failure-cases.md"
  ],
  "keywords": [
    "ganhuo-geo",
    "geo",
    "ai-search",
    "content-engineering",
    "skill"
  ]
}
